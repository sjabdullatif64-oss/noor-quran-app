<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme — dark green, no action bar -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#1a5c38</item>
        <item name="colorPrimaryDark">#071a0e</item>
        <item name="colorAccent">#1a5c38</item>
        <item name="android:windowBackground">#071a0e</item>
        <item name="android:statusBarColor">#071a0e</item>
        <item name="android:navigationBarColor">#071a0e</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash theme shown before the WebView loads -->
    <style name="AppTheme.NoActionBar" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- Immersive launch splash -->
    <style name="AppTheme.Launcher" parent="AppTheme.NoActionBar">
        <item name="android:windowBackground">@drawable/splash</item>
    </style>
</resources>
